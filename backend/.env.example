# App
APP_NAME="AquaAI Backend"
APP_VERSION="1.0.0"
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database — use postgresql+asyncpg:// for async, postgresql:// for sync/alembic
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/aquaai
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/aquaai

# Local file storage (no S3 needed for local dev)
UPLOAD_DIR=uploads
BASE_URL=http://localhost:8000

# Firebase FCM (leave blank to disable push notifications locally)
FIREBASE_CREDENTIALS_PATH=

# WhatsApp Business API (leave blank to disable locally)
WHATSAPP_API_URL=
WHATSAPP_TOKEN=

# Disease outbreak alert radius (km)
OUTBREAK_ALERT_RADIUS_KM=5

# Model update check interval (hours)
MODEL_UPDATE_CHECK_HOURS=24

# Certificate expiry (days)
CERTIFICATE_EXPIRY_DAYS=90

# HMAC secret for certificate signing
HMAC_SECRET=your-hmac-secret-change-this

# Redis (optional, for celery background tasks)
REDIS_URL=redis://localhost:6379/0

# Claude Opus 4 API key — powers the AI chat agent AND all image diagnostics
# (EHP disease, seed count, quality grading, multi-disease screening via vision).
# Without this key the backend runs on offline ML (sklearn + OpenCV blob detection).
ANTHROPIC_API_KEY=
