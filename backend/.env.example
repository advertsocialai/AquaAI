# App
APP_NAME="AquaAI Backend"
APP_VERSION="1.0.0"
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database — Supabase Postgres
# Project: aquaai3366's Project (oopipjgmweibqyvjzpzi, us-west-1)
# Dashboard → Project Settings → Database → Connection string
# Use the Session pooler (port 5432) for the backend; the Transaction pooler
# (port 6543) is for serverless. Async driver needs +asyncpg.
# Replace [YOUR-PASSWORD] with the DB password from Supabase Settings → Database.
DATABASE_URL=postgresql+asyncpg://postgres.oopipjgmweibqyvjzpzi:[YOUR-PASSWORD]@aws-0-us-west-1.pooler.supabase.com:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres.oopipjgmweibqyvjzpzi:[YOUR-PASSWORD]@aws-0-us-west-1.pooler.supabase.com:5432/postgres

# Supabase project (for backend → REST / storage / auth admin calls)
SUPABASE_URL=https://oopipjgmweibqyvjzpzi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=  # Settings → API → service_role secret. NEVER expose to clients.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_GLFB8zyDKA5XqZJ3l-L-iA_ZUoTPgNZ

# Local file storage (no S3 needed for local dev)
UPLOAD_DIR=uploads
BASE_URL=http://localhost:8000

# Firebase FCM (leave blank to disable push notifications locally)
FIREBASE_CREDENTIALS_PATH=

# WhatsApp Business API (leave blank to disable locally)
WHATSAPP_API_URL=
WHATSAPP_TOKEN=

# Disease outbreak alert radius (km)
OUTBREAK_ALERT_RADIUS_KM=5

# Model update check interval (hours)
MODEL_UPDATE_CHECK_HOURS=24

# Certificate expiry (days)
CERTIFICATE_EXPIRY_DAYS=90

# HMAC secret for certificate signing
HMAC_SECRET=your-hmac-secret-change-this

# Redis (optional, for celery background tasks)
REDIS_URL=redis://localhost:6379/0

# Claude Opus 4 API key — powers the AI chat agent AND all image diagnostics
# (EHP disease, seed count, quality grading, multi-disease screening via vision).
# Without this key the backend runs on offline ML (sklearn + OpenCV blob detection).
ANTHROPIC_API_KEY=
