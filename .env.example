# Frontend (Vite) — copy to .env.local for local dev.
# Real .env files are gitignored; this template is safe to commit.

# Aqua AI backend (FastAPI). Locally:  http://localhost:8000/api/v1
VITE_API_BASE=http://localhost:8000/api/v1

# Supabase — project: aqua-ai (rjhysiqqwgptqiwsonvd, us-east-1, org lziyuuljgoeapcddzosm)
# These two are SAFE to ship to the browser. RLS protects the data.
# (Same project used by Vercel preview + production; separate dev project TBD.)
VITE_SUPABASE_URL=https://rjhysiqqwgptqiwsonvd.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ffKdBSjZkIBPo-MFWCgB4w_di3tqXL3

# Web push (VAPID). The PUBLIC key is safe in the browser; it has a built-in
# default so push works without setting this. Override only if you rotate keys.
VITE_VAPID_PUBLIC_KEY=BFWRhIMUFbuaRcMc26y3fq5FfMZI6eZwGR3HH7IJrKY-ecze47VQkTWVcTzSq3YsO9q_Vi9DOiayCMU2DYRZO3k
# The PRIVATE key is backend-only — NEVER ship to the browser. Set it on the
# FastAPI server (e.g. backend/.env): VAPID_PRIVATE_KEY=xWX5S6th9IqpVUOHJqbOMcf8uoREyatzuwX_xqz4OTs

# Sentry (optional)
VITE_SENTRY_DSN=
